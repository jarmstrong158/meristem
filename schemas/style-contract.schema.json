{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "meristem:style-contract",
  "title": "Style contract",
  "description": "The locked palette + canvas/outline/shading/anchor rules. Permissive on notes/extras so hand-authored contracts (with $schema_note etc.) validate.",
  "type": "object",
  "required": ["name", "palette", "canvas"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1 },
    "palette": {
      "type": "object",
      "required": ["colors"],
      "properties": {
        "source": { "type": "string" },
        "license": { "type": "string" },
        "colors": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "items": {
            "type": "object",
            "required": ["i", "hex", "name"],
            "properties": {
              "i": { "type": "integer", "minimum": 0 },
              "hex": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
              "name": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "canvas": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["w", "h"],
        "properties": {
          "w": { "type": "integer", "minimum": 1 },
          "h": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "outline": { "type": "object" },
    "shading": { "type": "object" },
    "anchor": { "type": "object" },
    "background": { "type": "object" },
    "grid": { "type": "object" },
    "naming": { "type": "object" }
  }
}
