{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "meristem:mechanics",
  "title": "Mechanics",
  "description": "Parameters over a FIXED archetype library. Never freeform code. Each selected archetype has a typed parameter set.",
  "type": "object",
  "additionalProperties": false,
  "required": ["archetypes"],
  "properties": {
    "archetypes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "params"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "kind": { "enum": ["platformer_controller", "top_down_controller", "turn_based_combat"] },
          "params": { "type": "object" }
        },
        "allOf": [
          {
            "if": { "properties": { "kind": { "const": "platformer_controller" } } },
            "then": {
              "properties": {
                "params": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["move_speed", "accel", "jump_height", "gravity"],
                  "properties": {
                    "move_speed": { "type": "number", "exclusiveMinimum": 0 },
                    "accel": { "type": "number", "exclusiveMinimum": 0 },
                    "jump_height": { "type": "number", "exclusiveMinimum": 0 },
                    "gravity": { "type": "number", "exclusiveMinimum": 0 },
                    "coyote_time": { "type": "number", "minimum": 0 },
                    "jump_buffer": { "type": "number", "minimum": 0 },
                    "air_control": { "type": "number", "minimum": 0, "maximum": 1 }
                  }
                }
              }
            }
          },
          {
            "if": { "properties": { "kind": { "const": "top_down_controller" } } },
            "then": {
              "properties": {
                "params": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["move_speed", "accel"],
                  "properties": {
                    "move_speed": { "type": "number", "exclusiveMinimum": 0 },
                    "accel": { "type": "number", "exclusiveMinimum": 0 },
                    "friction": { "type": "number", "minimum": 0 },
                    "diagonal_normalized": { "type": "boolean" }
                  }
                }
              }
            }
          },
          {
            "if": { "properties": { "kind": { "const": "turn_based_combat" } } },
            "then": {
              "properties": {
                "params": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["initiative_stat", "damage_formula"],
                  "properties": {
                    "initiative_stat": { "type": "string", "minLength": 1 },
                    "damage_formula": { "enum": ["atk_minus_def", "atk_times_mult", "flat"] },
                    "crit_chance": { "type": "number", "minimum": 0, "maximum": 1 },
                    "crit_multiplier": { "type": "number", "minimum": 1 }
                  }
                }
              }
            }
          }
        ]
      }
    }
  }
}
