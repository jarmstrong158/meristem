extends CharacterBody2D
## Generated enemy '{{name}}'. Vertical-slice placeholder behavior: idle bob.
## Real AI archetypes come later; the manifest already carries its stats.

@export var hp: int = {{hp}}
@export var atk: int = {{atk}}

var _t: float = 0.0
var _home_y: float = 0.0

func _ready() -> void:
	add_to_group("enemies")
	_home_y = position.y

func _physics_process(delta: float) -> void:
	_t += delta
	position.y = _home_y + sin(_t * 2.0) * 1.0
